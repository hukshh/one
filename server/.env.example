# ─────────────────────────────────────────────────────
# MeetingMind — Server Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────

# Server
PORT=4000
NODE_ENV=development

# ── Database (MongoDB Atlas) ───────────────────────
# Used for all data AND file storage (GridFS)
# No AWS S3 or external storage needed
DATABASE_URL="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/meetingmind?retryWrites=true&w=majority"

# ── Redis (BullMQ) ─────────────────────────────────
# Use REDIS_URL for managed Redis (Render, Upstash, etc.)
REDIS_URL=redis://localhost:6379
# OR use host/port for local dev:
# REDIS_HOST=localhost
# REDIS_PORT=6379

# ── AI Providers ───────────────────────────────────
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...

# ── Email (Resend SMTP) ────────────────────────────
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_USER=resend
EMAIL_PASS=re_...

# ── CORS / URLs ────────────────────────────────────
# Set FRONTEND_URL to your Vercel URL in production
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:4000
