{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    // File Layout
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "CommonJS",
    "target": "ES2020",
    "esModuleInterop": true,
    "lib": ["ES2020"],
    "types": ["node"],
    // For nodejs:
    // "lib": ["esnext"],
    // "types": ["node"],
    // and npm install -D @types/node

    // Other Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Style Options
    // "noImplicitReturns": true,
    // "noImplicitOverride": true,
    // "noUnusedLocals": true,
    // "noUnusedParameters": true,
    // "noFallthroughCasesInSwitch": true,
    // "noPropertyAccessFromIndexSignature": true,

    // Recommended Options
    "strict": false,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "jsx": "react-jsx",
    "skipLibCheck": true
  },
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*-test.ts",
    "src/test-*.ts",
    "src/debug-*.ts",
    "src/seed.ts",
    "src/get-ids.ts",
    "src/infra-test.ts",
    "src/email-test.ts",
    "src/test-trigger.ts",
    "src/e2e-stress-test.ts",
    "src/test-key.ts"
  ]
}
